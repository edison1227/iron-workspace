---
// 這裡區塊是 Astro 的 Server-side 執行區 (Build 時執行，不佔用前端 JS 資源)
const pageTitle = "ARMOR | 極致輕量化碳纖維自行車輪組";
const pageDescription = "專為賽道而生，ARMOR 運用航太級碳纖維技術與尖端空氣力學，為專業自行車手打造無可挑剔的極速體驗。";
const canonicalURL = "https://www.armor-wheels.com/"; // 替換成你未來的正式網域
---

<html lang="zh-TW" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalURL} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Brand",
      "name": "ARMOR",
      "description": pageDescription,
      "url": canonicalURL,
      "industry": "Bicycle Manufacturing"
    })} />
  </head>
  <body class="bg-zinc-950 text-zinc-50 antialiased selection:bg-cyan-500 selection:text-white">
    
    <main class="relative h-screen w-full overflow-hidden">
      
      <video 
        class="absolute top-0 left-0 w-full h-full object-cover z-0"
        autoplay 
        loop 
        muted 
        playsinline
        poster="/hero-poster.webp"
      >
        <source src="https://videos.pexels.com/video-files/5818973/5818973-uhd_2560_1440_24fps.mp4" type="video/mp4" />
      </video>

      <div class="absolute inset-0 z-10 bg-gradient-to-b from-zinc-950/70 via-zinc-950/40 to-zinc-950/90 backdrop-blur-[2px]"></div>

      <div class="relative z-20 flex h-full flex-col items-center justify-center px-4 text-center">
        <div class="mb-6 h-1 w-24 bg-gradient-to-r from-cyan-500 to-blue-600"></div>
        
        <h1 class="mb-4 text-5xl font-black uppercase tracking-tighter sm:text-7xl md:text-8xl lg:text-9xl">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-zinc-100 to-zinc-500">
            Forged in
          </span>
          <br />
          <span class="text-white">Speed.</span>
        </h1>
        
        <p class="mb-10 max-w-2xl text-lg font-light text-zinc-300 sm:text-xl md:text-2xl">
          航太級碳纖維與尖端空氣力學的完美融合。<br class="hidden sm:block" />
          為突破極限而生，重新定義賽道標準。
        </p>

        <div class="flex flex-col gap-4 sm:flex-row">
          <a href="#explore" class="group relative overflow-hidden bg-white px-8 py-4 text-sm font-bold uppercase tracking-widest text-zinc-950 transition-all hover:bg-zinc-200">
            <span class="relative z-10">探索 ARMOR 輪組</span>
            <div class="absolute inset-0 h-full w-0 bg-cyan-500 transition-all duration-300 ease-out group-hover:w-full z-0"></div>
            <span class="absolute inset-0 z-10 flex items-center justify-center text-white opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              探索 ARMOR 輪組
            </span>
          </a>
        </div>
      </div>
      
    </main>

  </body>
</html>